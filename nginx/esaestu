# 1. Редирект с HTTP на HTTPS
server {
    listen 80;
    server_name esaestu.casa www.esaestu.casa;
    return 301 https://$host$request_uri;
}

# 2. Основной блок HTTPS
server {
    listen 443 ssl;
    server_name esaestu.casa www.esaestu.casa;

    # SSL настройки
    ssl_certificate /etc/letsencrypt/live/esaestu.casa/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/esaestu.casa/privkey.pem;
    
    # Рекомендованные настройки безопасности
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Безопасные заголовки (Security Headers)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Content-Security-Policy "default-src 'self' http: https: data: blob: 'unsafe-inline'" always;



    access_log /var/log/nginx/main_access.log;
    error_log /var/log/nginx/main_error.log;

    location /static/ {
        alias /var/www/esaestu/staticfiles/;
    }

    location /media/ {
        alias /var/www/esaestu/media/;
        location ~* \.(php|pl|py|jsp|asp|sh|cgi|html|htm|svg)$ {
        # Возвращаем статус 403 Forbidden (Доступ запрещен) при попытке их открыть
        return 403;
    }
    
        # Добавляем HTTP-заголовок, запрещающий браузеру самостоятельно угадывать тип файла (MIME-sniffing)
        # Это предотвращает ситуации, когда браузер выполняет текстовый файл как скрипт
        add_header X-Content-Type-Options nosniff;
    }

    location / {
        include proxy_params;
        # Меняем путь на тот, который виден в вашем ps aux
        proxy_pass http://unix:/var/www/esaestu/esaestu.sock;
        proxy_set_header X-Forwarded-Proto $scheme;
   }


   location /sharing/ {
        alias /var/www/esaestu/sharing/;
        expires 30d;
        add_header Access-Control-Allow-Origin *; # Чтобы почтовики не блокировали
    }

}
