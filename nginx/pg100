# 1. Редирект с HTTP на HTTPS
server {
    listen 80;
    server_name perezgaldos100.esaestu.casa;
    return 301 https://$host$request_uri;
}

# 2. Основной блок HTTPS
server {
    listen 443 ssl;
    server_name perezgaldos100.esaestu.casa;

    # Используем тот же Wildcard сертификат
    ssl_certificate /etc/letsencrypt/live/esaestu.casa/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/esaestu.casa/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Безопасные заголовки (Security Headers)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Content-Security-Policy "default-src 'self' http: https: data: blob: 'unsafe-inline'" always;




    access_log /var/log/nginx/sub_access.log;
    error_log /var/log/nginx/sub_error.log;

    location /static/ {
        alias /var/www/pg100/staticfiles/;
    }

    location /media/ {
        alias /var/www/pg100/media/;
    }

    location / {
        include proxy_params;
        proxy_pass http://unix:/var/www/pg100/pg100.sock;
        proxy_set_header X-Forwarded-Proto $scheme;
   }
}
